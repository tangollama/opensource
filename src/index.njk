{# ---- Hero ---- #}
<section class="hero-page" aria-labelledby="hero-title" id="hero">

  {# Horizontal grid lines — SVG required for mix-blend-mode against WebGL canvas #}
  <svg class="hero-hlines" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" preserveAspectRatio="none">
    <line x1="0" y1="20%" x2="100%" y2="20%"/>
    <line x1="0" y1="40%" x2="100%" y2="40%"/>
    <line x1="0" y1="60%" x2="100%" y2="60%"/>
    <line x1="0" y1="80%" x2="100%" y2="80%"/>
    <line x1="0" y1="100%" x2="100%" y2="100%"/>
  </svg>

  {# WebGL liquid gradient background #}
  <div id="hero-bg" aria-hidden="true">
    <div id="hero-fade" aria-hidden="true"></div>
  </div>

  {# circles.png overlay — mix-blend-mode: overlay #}
  <img src="/assets/images/circles.png" class="hero-circles-overlay" aria-hidden="true" />

  {# SVG headline — required for mix-blend-mode to composite against the WebGL canvas #}
  {# Open + Source — blend mode toggles to normal on Enter #}
  <svg
    class="hero-svg-text"
    xmlns="http://www.w3.org/2000/svg"
    role="img"
    aria-label="Open Source"
    id="hero-title"
  >
    <text class="svg-open">Open</text>
    <text class="svg-source">Source</text>
  </svg>

  {# BibleProject — always overlay, never toggled #}
  <svg class="hero-svg-bp" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
    <text class="svg-bibleproject">BibleProject</text>
  </svg>


</section>

{# ---- Mission ---- #}
<section class="mission-section" id="mission">
  <div class="mission-container">
    <p class="mission-text">
      BibleProject is a nonprofit animation studio and Bible-education platform creating free resources to help people experience the Bible as a unified story leading to Jesus.   </br></br>
      This site hosts open source tools, fonts, and assets that developers and designers can use in projects that share or reference BibleProject content.
    </p>
  </div>
</section>

