<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content="{{ description or site.description }}" />
  <title>{% if title %}{{ title }} — {% endif %}{{ site.title }}</title>

  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link rel="preconnect" href="https://cdnjs.cloudflare.com" />
  <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Cascadia+Code:ital,wght@0,100;0,400;0,700;1,100;1,400&family=Heebo:wght@700&display=swap" />

  <link rel="stylesheet" href="/assets/css/style.css" />
  <link rel="stylesheet" href="/assets/css/index.css" />
  <link rel="icon" href="/assets/images/favicon.ico" type="image/x-icon" />
</head>
<body class="home-body">

  <!-- Full-height vertical grid lines — 6 equal columns within the 1140px content container -->
  <svg class="site-vlines" aria-hidden="true" xmlns="http://www.w3.org/2000/svg">
    <line x1="0%"      y1="0" x2="0%"      y2="100%"/>
    <line x1="16.667%" y1="0" x2="16.667%" y2="100%"/>
    <line x1="33.333%" y1="0" x2="33.333%" y2="100%"/>
    <line x1="50%"     y1="0" x2="50%"     y2="100%"/>
    <line x1="66.667%" y1="0" x2="66.667%" y2="100%"/>
    <line x1="83.333%" y1="0" x2="83.333%" y2="100%"/>
    <line x1="100%"    y1="0" x2="100%"    y2="100%"/>
  </svg>

  <!-- Top-left logo badge -->
  <a href="/" class="site-logo-badge" aria-label="BibleProject Open Source — Home">
    <img src="/assets/images/bp-logo-white.svg" alt="BibleProject" width="20" height="20" />
    <span class="logo-badge-text"><strong>BibleProject</strong> Open Source</span>
  </a>

  <main id="main-content">
    {{ content | safe }}
  </main>


  <script defer src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.2/gsap.min.js"></script>
  <script defer src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.2/ScrollTrigger.min.js"></script>
  <script defer src="https://cdnjs.cloudflare.com/ajax/libs/three.js/r128/three.min.js"></script>
  <script defer src="/assets/js/liquid-gradient.js"></script>
  <script defer src="/assets/js/index.js"></script>
</body>
</html>
