---
layout: layouts/base.njk
title: Downloads
description: Download BibleProject brand assets including fonts and logo files
---

<div class="page-wrapper">
  <div class="container">

    <header class="section-header">
      <h1 class="section-title">Downloads</h1>
      <p class="section-desc">
        Brand assets available for download and use in projects that reference or represent BibleProject.
        Review the attribution notes on each asset before use.
      </p>
    </header>

    <div class="download-list">
      {% for asset in downloads %}
      <article class="download-card">
        <div class="download-card-body">
          <h2 class="download-card-name">{{ asset.name }}</h2>
          <p class="download-card-desc">{{ asset.description }}</p>
          {% if asset.attribution %}
          <p class="download-card-attribution">{{ asset.attribution }}</p>
          {% endif %}
        </div>
        <div class="download-card-action">
          <a
            href="/assets/downloads/{{ asset.filename }}"
            class="btn btn-primary"
            download
            aria-label="Download {{ asset.name }}"
          >
            Download
          </a>
        </div>
      </article>
      {% endfor %}
    </div>

    <aside style="margin-top: 3rem; padding: 1.5rem; background: var(--color-bg-subtle); border-radius: 0.5rem; border: 1px solid var(--color-border);">
      <h2 style="font-size: 1rem; font-weight: 700; margin-bottom: 0.5rem;">Brand usage guidelines</h2>
      <p style="font-size: 0.9rem; color: var(--color-text-muted);">
        Assets from BibleProject are subject to their brand guidelines.
        Always link back to
        <a href="{{ site.bpUrl }}" target="_blank" rel="noopener noreferrer">bibleproject.com</a>
        when using their content, and do not alter logos or artwork.
        For questions, visit the
        <a href="{{ site.bpUrl }}/about/brand-guidelines/" target="_blank" rel="noopener noreferrer">BibleProject brand page</a>.
      </p>
    </aside>

  </div>
</div>
